# Option A: browser calls Go API directly.
NEXT_PUBLIC_API_BASE=https://api.agent-gateway.site

# Option B: browser calls same Next domain paths like /auth and Next rewrites to Go API.
# Use this when hosting https://agent-gateway.site and proxying from Next.
# NEXT_PUBLIC_API_BASE=
# SERVER_API_BASE=https://api.agent-gateway.site
